{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "prisma/seed.ts"],
  "exclude": ["dist", "node_modules"]
}